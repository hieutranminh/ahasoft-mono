# Application Configuration
VITE_APP_NAME="Ahasoft System"
VITE_APP_VERSION="1.0.0"
VITE_APP_ENV="localhost"  # localhost | development | staging | production

# Gateway & API Configuration
VITE_GATEWAY_BASE_URL="https://localhost:44001"
VITE_API_TIMEOUT=30000

# Notification Configuration (SignalR)
VITE_NOTIFICATION_URL="https://example.service.signalr.net/client/?hub=salonadmin"

# Login URLs
VITE_LOGIN_URL_DEFAULT="login"
VITE_LOGIN_URL_KR="login"

# Mobile App Parameters (optional, typically absent in local)
# VITE_PARAM_MOBILE_APP="?isMobileApp=true"
# VITE_PARAM_VERSION="&version=1.2"

# Azure Storage URLs
VITE_AZURE_STORAGE_BOARD_URL="https://example.blob.core.windows.net/boards/"
VITE_AZURE_STORAGE_MESSAGE_URL="https://example.blob.core.windows.net/messages/"
VITE_AZURE_STORAGE_CLIENT_URL="https://example.blob.core.windows.net/clients/"
VITE_AZURE_STORAGE_ADMINS_URL="https://example.blob.core.windows.net/admins/"

# Third-party Keys
VITE_IAMPORT_KEY="imp00000000"
VITE_ARS_MID_ID="testpay01m"

# Feature Flags
VITE_ENABLE_DEVTOOLS=false
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_DEBUG_MODE=false

# Logging Configuration
VITE_LOG_LEVEL="error"  # debug | info | warn | error

# Optional: Analytics & Monitoring
# VITE_SENTRY_DSN=your_sentry_dsn_here
# VITE_GA_TRACKING_ID=your_google_analytics_id_here

# PWA Configuration
VITE_ENABLE_PWA=false

# Dev Server Configuration (optional)
# VITE_DEV_PORT=8080
# VITE_PREVIEW_PORT=8000
